# Proton Bridge credentials (find these in Proton Bridge > Mailbox details)
PROTON_EMAIL=your@proton.me
PROTON_BRIDGE_PASSWORD=your-bridge-generated-password

# Proton Bridge ports (defaults shown, change if you've customized Bridge settings)
PROTON_IMAP_PORT=1143
PROTON_SMTP_PORT=1025

# ElevenLabs (get your API key at elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=sk_your_api_key_here
ELEVENLABS_AGENT_ID=
